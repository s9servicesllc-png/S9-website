<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>S9 Property Development & Construction | Byron MI General Contractor</title>
  <meta
    name="description"
    content="S9 Property Development & Construction provides start-to-finish residential construction, roofing, decks, additions, and property development in Byron, Michigan serving Shiawassee County, Livingston County, and surrounding areas."
  />
  <style>
    :root {
      --bg: #f7f5f1;
      --white: #ffffff;
      --text: #1f2937;
      --muted: #5b6472;
      --dark: #111827;
      --accent: #8b5e3c;
      --border: #ddd6cf;
      --soft: #efe8e1;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      max-width: 100%;
      display: block;
    }

    .topbar {
      background: var(--dark);
      color: #fff;
      padding: 10px 20px;
      font-size: 14px;
      text-align: center;
    }

    .topbar span {
      display: inline-block;
      margin: 0 10px;
    }

    header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(255, 255, 255, 0.96);
      border-bottom: 1px solid var(--border);
      backdrop-filter: blur(8px);
    }

    .nav-wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 14px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      flex-wrap: wrap;
    }

    .brand {
      flex: 1 1 250px;
    }

    .brand .small {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--muted);
      margin-bottom: 4px;
    }

    .brand .name {
      font-size: 24px;
      font-weight: 700;
      line-height: 1.2;
    }

    nav {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      align-items: center;
      justify-content: center;
      flex: 2 1 500px;
    }

    nav a {
      font-size: 15px;
      color: var(--text);
      padding: 8px 4px;
    }

    .nav-btn {
      background: var(--dark);
      color: #fff;
      padding: 12px 18px;
      border-radius: 14px;
      font-weight: 700;
      display: inline-block;
    }

    .hero {
      background: linear-gradient(rgba(17,24,39,0.68), rgba(17,24,39,0.68)),
        url("https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=1600&q=80") center/cover no-repeat;
      color: #fff;
      padding: 90px 20px;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .hero-content {
      max-width: 760px;
    }

    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-size: 13px;
      font-weight: 700;
      opacity: 0.9;
    }

    h1 {
      font-size: 50px;
      line-height: 1.1;
      margin: 16px 0 18px;
    }

    .hero p {
      font-size: 18px;
      max-width: 700px;
      color: rgba(255,255,255,0.92);
    }

    .hero-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-top: 28px;
    }

    .btn {
      display: inline-block;
      padding: 14px 22px;
      border-radius: 14px;
      font-weight: 700;
      transition: 0.2s ease;
    }

    .btn-primary {
      background: var(--accent);
      color: #fff;
    }

    .btn-secondary {
      background: rgba(255,255,255,0.14);
      color: #fff;
      border: 1px solid rgba(255,255,255,0.3);
    }

    .btn:hover,
    .nav-btn:hover {
      opacity: 0.92;
    }

    section {
      padding: 70px 20px;
    }

    .section-white {
      background: var(--white);
    }

    .section-soft {
      background: var(--soft);
    }

    .section-title {
      max-width: 760px;
      margin-bottom: 36px;
    }

    .section-title h2 {
      font-size: 36px;
      line-height: 1.15;
      margin: 10px 0 14px;
    }

    .section-title p {
      color: var(--muted);
      font-size: 17px;
      margin: 0;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 24px;
    }

    .grid-3 {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 24px;
    }

    .grid-4 {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 18px;
    }

    .card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 24px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.04);
    }

    .card h3 {
      margin-top: 0;
      margin-bottom: 10px;
      font-size: 22px;
    }

    .card p {
      margin: 0;
      color: var(--muted);
    }

    .service-list .card h3 {
      font-size: 20px;
    }

    .process-step {
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--accent);
      font-weight: 700;
      margin-bottom: 12px;
    }

    .list-clean {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .list-clean li {
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
      color: var(--muted);
    }

    .leadership-name {
      font-size: 22px;
      font-weight: 700;
      margin-bottom: 4px;
    }

    .leadership-role {
      font-weight: 700;
      color: var(--accent);
      margin-bottom: 12px;
      font-size: 15px;
    }

    .cta-box {
      background: var(--dark);
      color: #fff;
      border-radius: 28px;
      padding: 36px;
    }

    .cta-box p {
      color: rgba(255,255,255,0.85);
    }

    .projects-coming {
      text-align: center;
      font-size: 18px;
      color: var(--muted);
      padding: 40px 20px;
      border: 2px dashed var(--border);
      border-radius: 22px;
      background: var(--white);
    }

    .service-area-list {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

